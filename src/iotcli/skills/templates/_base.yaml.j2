# iotcli AI Agent Skill — Global Template
# Auto-generated by iotcli skills generate
# This file describes how an AI agent should interact with iotcli.

tool:
  name: iotcli
  description: >
    Universal IoT CLI for controlling smart home devices.
    Supports: Xiaomi miIO, Tuya, MQTT (Zigbee), HTTP (ESPHome/Tasmota), LG AC.
    All commands accept --json for machine-readable output.

  rules:
    - Always use the --json flag for structured output.
    - Never call interactive commands (iotcli setup) — use non-interactive mode only.
    - Never guess device names — query them dynamically with `iotcli --json list`.
    - Always check device status before controlling (it may be offline).

  commands:
    list:
      syntax: "iotcli --json list"
      description: "List all configured devices with names, protocols, IPs, and status."

    status_all:
      syntax: "iotcli --json status-all"
      description: "Query live status of ALL devices in parallel. Returns power state, temperature, etc."

    status:
      syntax: 'iotcli --json control status "<device_name>"'
      description: "Query a single device's live status."

    turn_on:
      syntax: 'iotcli --json control on "<device_name>"'
      description: "Turn a device on."

    turn_off:
      syntax: 'iotcli --json control off "<device_name>"'
      description: "Turn a device off."

    set_property:
      syntax: 'iotcli --json control set "<device_name>" "<property>=<value>"'
      description: "Set a specific property on a device."

  workflow:
    - step: 1
      action: "Run `iotcli --json list` to discover available devices."
    - step: 2
      action: "Run `iotcli --json control status <device>` to check current state."
    - step: 3
      action: "Run the appropriate control command (on/off/set)."
    - step: 4
      action: "Optionally re-fetch status to confirm the command took effect."

{% if devices %}
  devices:
  {% for dev in devices %}
    - name: "{{ dev.name }}"
      protocol: "{{ dev.protocol }}"
      ip: "{{ dev.ip }}"
      {% if dev.profile %}
      profile: "{{ dev.profile }}"
      {% endif %}
      capabilities:
      {% for cap in dev.capabilities %}
        - "{{ cap }}"
      {% endfor %}
      {% if dev.settable_properties %}
      settable_properties:
      {% for prop in dev.settable_properties %}
        - "{{ prop }}"
      {% endfor %}
      {% endif %}
      {% if dev.actions %}
      custom_actions:
      {% for action_name, action_desc in dev.actions.items() %}
        - name: "{{ action_name }}"
          description: "{{ action_desc }}"
          syntax: 'iotcli --json control set "{{ dev.name }}" "{{ action_name }}=<value>"'
      {% endfor %}
      {% endif %}
  {% endfor %}
{% endif %}
